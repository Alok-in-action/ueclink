{
  "rules": {
    "sessions": {
      ".read": "auth != null && auth.token.email === 'ueclink@gmail.com'",
      "$sessionId": {
        ".read":  "auth != null && (data.child('users').child(auth.uid).exists() || auth.token.email === 'ueclink@gmail.com')",
        ".write": "auth != null && (data.child('users').child(auth.uid).exists() || !data.exists() || auth.token.email === 'ueclink@gmail.com')",
        "messages": {
          "$msgId": {
            ".write": "auth != null"
          }
        },
        "typing": {
          "$userId": {
            ".write": "auth != null && auth.uid == $userId"
          }
        },
        "reveal": {
          "$userId": {
            ".write": "auth != null && auth.uid == $userId"
          }
        }
      }
    }
  }
}

