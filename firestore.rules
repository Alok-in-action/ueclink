rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Matching queue — any logged-in user can read all (needed for matchmaking)
    // but can only write their own entry
    match /matchingQueue/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      // Allow the matching logic to update partner's doc too
      allow update: if request.auth != null;
    }

    // Reports — write only
    match /reports/{docId} {
      allow create: if request.auth != null;
      allow read: if false;
    }

    // Meta config — read by all authenticated users
    match /meta/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
